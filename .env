# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Cadena de conexión PostgreSQL de Supabase (Session Mode, puerto 5432)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Clave secreta para firmar/verificar los JWT del sistema
JWT_SECRET=CAMBIA_ESTO_POR_UN_SECRETO_LARGO_Y_SEGURO

# ─── WHATSAPP CLOUD API ───────────────────────────────────────────────────────
# Token de verificación que Meta enviará al crear el webhook
WHATSAPP_VERIFY_TOKEN=CAMBIA_ESTO_POR_TU_TOKEN_DE_VERIFICACION

# ─── OPENAI (Whisper — Transcripción de audio) ────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── CEREBRAS (Clasificación de intención) ────────────────────────────────────
CEREBRAS_API_KEY=csk-...

# ─── SUPABASE STORAGE ─────────────────────────────────────────────────────────
# Service Role Key (con permisos de escritura al bucket)
# La encuentras en: Supabase Dashboard → Settings → API → service_role
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Nombre del bucket donde se guardan los audios de WhatsApp
STORAGE_BUCKET_NAME=whatsapp-media

# ─── FRONTEND (Next.js) ───────────────────────────────────────────────────────
# URL pública de tu API (local en desarrollo, Workers URL en producción)
NEXT_PUBLIC_API_URL=http://localhost:3001
